# HTTP
APP_ADDR=:9010

# store_backend: memory | postgres
STORE_BACKEND=postgres
DATABASE_URL=postgres://traffic:traffic@127.0.0.1:5432/traffic_analysis?sslmode=disable
AUTO_MIGRATE=true

# 内部接口鉴权，对应原 adapter 的 X-API-Key
INTERNAL_API_KEY=change-me-internal-key

# FlowShadow / ly_server
FLOWSHADOW_BASE_URL=http://127.0.0.1:18080
FLOWSHADOW_API_KEY=

# DeepSOC 上游；若为空，Go 服务使用本地数据库实现兼容 DeepSOC API
DEEPSOC_BASE_URL=
DEEPSOC_USERNAME=admin
DEEPSOC_PASSWORD=admin
DEEPSOC_API_KEY=

# OpenAI-compatible LLM，可接 DeepSeek/OpenAI/私有网关；为空则 engineer-chat 返回占位回复
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=deepseek-chat

# 同步参数
SYNC_BATCH_SIZE=200
SYNC_LOOKBACK_SECONDS=600
SYNC_MAX_RETRIES=5
HTTP_TIMEOUT_SECONDS=15

# MQ: none | rabbitmq
MQ_BACKEND=rabbitmq
RABBITMQ_URL=amqp://traffic:traffic@127.0.0.1:5672/
RABBITMQ_EXCHANGE=traffic.events
RABBITMQ_EVENT_QUEUE=traffic.events.default
RABBITMQ_CONSUMER_ENABLED=true
